# pii_masker_v2-scoped gitignore — does not affect the repo root layout.

# Python build / cache artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
build/
dist/
.installed.cfg
pip-log.txt
pip-delete-this-directory.txt

# Test / coverage artifacts
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.hypothesis/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# Demo / example outputs
demo_audit_log.jsonl
demo_audit_log.csv
stt_audit.jsonl
*.pyc

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp

# Never commit real-world data dumps
/data/
/private/
